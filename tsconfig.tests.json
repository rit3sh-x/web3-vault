{
    "compilerOptions": {
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tests.tsbuildinfo",
        "target": "ES2022",
        "lib": ["ES2022"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "types": ["node"],
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "noEmit": true,
        "baseUrl": ".",
        "paths": {
            "@contracts/*": ["./target/types/*"],
            "@idl/*": ["./target/idl/*"]
        }
    },
    "include": ["tests/**/*.ts"]
}
